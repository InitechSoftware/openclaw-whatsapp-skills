# Copy to .env and fill in. Never commit the filled version.

# Random secret used as ?secret=<token> on the registered webhook URL.
# Generate with: openssl rand -hex 16
WEBHOOK_SECRET=

# TimelinesAI workspace token — same one the rest of the guide uses.
TIMELINES_AI_API_KEY=

# The "customer" side — a WhatsApp number you've connected to
# TimelinesAI specifically for test scenarios. DO NOT reuse your real
# business number for this.
PERSONA_JID=15550100@s.whatsapp.net
PERSONA_PHONE=+15550100

# The "agent-under-test" side — the WhatsApp number your real skill
# stack will answer on during the test. This can be your dev number.
AGENT_UNDER_TEST_JID=15550200@s.whatsapp.net
AGENT_UNDER_TEST_PHONE=+15550200
