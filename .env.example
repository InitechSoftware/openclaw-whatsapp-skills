# Copy this file to .env and fill in the values.
# Every skill in this repo reads its config from these environment variables.

# --- Required for every skill -----------------------------------------------

# Your TimelinesAI public API Bearer token.
# Get one at: https://app.timelines.ai → Integrations → Public API → Copy.
# One token covers your whole workspace.
TIMELINES_AI_API_KEY=

# The JID (WhatsApp account ID) your skills are allowed to send from.
# Format: "PHONE@s.whatsapp.net" — e.g. "15550100@s.whatsapp.net".
# Find it by calling GET /whatsapp_accounts with your token and copying the `id` field.
# REQUIRED if your workspace has more than one WhatsApp number connected.
# Single-number workspaces can leave this blank.
ALLOWED_SENDER_JID=

# --- Required for the webhook receiver (examples/vercel-webhook-receiver) ---

# Where your OpenClaw agent receives invocations from the webhook handler.
# Format: an HTTPS URL on your OpenClaw host that accepts POST {chat_id, text, sender_phone}.
OPENCLAW_HOOK_URL=

# Random secret appended as ?secret=... to your webhook URL for minimal auth.
# Generate with: openssl rand -hex 16
WEBHOOK_SECRET=
